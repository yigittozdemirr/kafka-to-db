# ==============================================================================
# Root .gitignore for Distributed Kafka Microservices Architecture
# ==============================================================================

# --- System / OS Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- IDEs & Editors ---
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse
.metadata/
.classpath
.project
.settings/
.factorypath
.springBeans
.sts4-cache/
*.tmp
*.bak

# VS Code
.vscode/
.history/
*.code-workspace
.vscode-test/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# --- Build & Dependency Directories ---
# Java / Maven
**/target/
**/build/
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
!**/src/main/**/build/
!**/src/test/**/build/
release.properties
pom.xml.releaseBackup
pom.xml.tagBackup
pom.xml.next
dependency-reduced-pom.xml

# Node.js / Frontend
**/node_modules/
**/dist/
**/dist-ssr/
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/.env
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
.stylelintcache
.svelte-kit/
.next/
.nuxt/
.output/

# --- Docker & Monitoring Volumes (Local Temp/Data) ---
# Ignore any local data folders generated by Docker volumes if mapped
# e.g., local-data/, postgres-data/, prometheus-data/, grafana-data/
**/pgdata/
**/kafka-data/
**/grafana-data/
*.db
*.sqlite

# --- Log Files ---
*.log
logs/
**/logs/
